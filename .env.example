# Copy to .env (gitignored) and fill in. Never commit real secrets.

# OpenRouter (OpenAI-compatible) — used for the digest call. See ADR 003.
OPENROUTER_API_KEY=
# Optional: override the model id (defaults to anthropic/claude-3.5-haiku).
# OPENROUTER_MODEL=anthropic/claude-3.5-haiku

# Postgres connection string (Vercel Postgres / Neon). See ADR 001.
DATABASE_URL=

# Remote browser CDP websocket for the rendering fallback (ADR 004), e.g.
# Browserless: wss://chrome.browserless.io?token=...  When unset, a locally
# installed Playwright Chromium is launched (run: playwright install chromium).
# BROWSER_WS_ENDPOINT=
